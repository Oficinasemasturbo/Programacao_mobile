Algoritmo "Número positivo, negativo ou zero"

Var

n1: inteiro

Inicio

escreva ("Qual o número? ")
leia(n1)
se n1 < 0 entao
   escreva("Negativo")
senao
     se n1 > 0 entao
        escreva("Positivo")
senao
     se n1 = 0 entao
        escreva("Zero")
     fimse
fimse
fimse
Fimalgoritmo