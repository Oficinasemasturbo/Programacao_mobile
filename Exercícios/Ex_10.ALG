Algoritmo "maior número"

Var

n1: inteiro
n2: inteiro

Inicio

escreva ("Qual o primeiro numero? ")
leia(n1)
escreva ("Qual o segundo numero? ")
leia(n2)
se n1 = n2 entao
   escreva(n1, " e ", n2, " săo iguais")
senao
     se n1 > n2 entao
        escreva(n1, " é maior que ", n2)
senao
     escreva(n2, " é maior que ", n1)
     fimse
fimse
Fimalgoritmo