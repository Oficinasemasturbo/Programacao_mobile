Algoritmo "SomaDosPares"



Var

n: inteiro
i: inteiro
s: inteiro
im: inteiro

Inicio

s <- 0
para i de 1 ate 20 faca
     escreva("Digite o ", i, "║ n·mero: ")
     leia(n)
     se n mod 2 = 0 entao
        s <- s + n
     senao
          im <- im + 1
fimse
fimpara
escreva("Quantidade de n·meros Ēmpares digitados: ", im)
escreva(" Soma total dos Pares: ", s)

Fimalgoritmo